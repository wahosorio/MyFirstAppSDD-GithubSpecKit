@page "/documents/upload"
@using ContosoDashboard.Services
@using ContosoDashboard.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IDocumentService DocumentService
@inject IProjectService ProjectService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Upload Document - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1>Upload Document</h1>
            <p class="text-muted">Upload files securely and associate them with your projects.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="uploadModel" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Select File(s)</label>
                            <InputFile OnChange="OnInputFileChange" multiple />
                            @if (selectedFiles.Any())
                            {
                                <ul class="mt-2">
                                    @foreach (var file in selectedFiles)
                                    {
                                        <li>@file.Name (@String.Format("{0:N0}", file.Size) bytes)</li>
                                    }
                                </ul>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <InputText class="form-control" @bind-Value="uploadModel.Title" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <InputSelect class="form-select" @bind-Value="uploadModel.Category">
                                <option value="">Choose category</option>
                                @foreach (var category in Categories)
                                {
                                    <option value="@category">@category</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Associated Project</label>
                            <InputSelect class="form-select" @bind-Value="uploadModel.ProjectId">
                                <option value="">None</option>
                                @if (projects != null)
                                {
                                    @foreach (var project in projects)
                                    {
                                        <option value="@project.ProjectId">@project.Name</option>
                                    }
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tags (comma-separated)</label>
                            <InputText class="form-control" @bind-Value="tagsText" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="uploadModel.Description" rows="4" />
                        </div>

                        <div class="mb-3">
                            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">Upload</button>
                            <button class="btn btn-secondary ms-2" type="button" @onclick="ClearSelection" disabled="@isSubmitting">Clear</button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(statusMessage))
                        {
                            <div class="alert @statusClass">@statusMessage</div>
                        }
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly string[] Categories = new[]
    {
        "Project Documents",
        "Team Resources",
        "Personal Files",
        "Reports",
        "Presentations",
        "Other"
    };

    private DocumentUploadRequest uploadModel = new DocumentUploadRequest();
    private List<IBrowserFile> selectedFiles = new();
    private List<Project> projects = new();
    private int currentUserId;
    private bool isSubmitting;
    private string? statusMessage;
    private string statusClass = "alert-info";
    private string? tagsText;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
        {
            currentUserId = userId;
            projects = await ProjectService.GetUserProjectsAsync(currentUserId);
        }
    }

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles().ToList();
    }

    private async Task HandleValidSubmit()
    {
        if (!selectedFiles.Any())
        {
            statusMessage = "Please select at least one file to upload.";
            statusClass = "alert-warning";
            return;
        }

        if (string.IsNullOrWhiteSpace(uploadModel.Title))
        {
            statusMessage = "A document title is required.";
            statusClass = "alert-warning";
            return;
        }

        if (string.IsNullOrWhiteSpace(uploadModel.Category))
        {
            statusMessage = "A document category is required.";
            statusClass = "alert-warning";
            return;
        }

        isSubmitting = true;
        statusMessage = null;

        try
        {
            uploadModel.Tags = string.IsNullOrWhiteSpace(tagsText)
                ? new List<string>()
                : tagsText.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(tag => tag.Trim()).ToList();

            foreach (var file in selectedFiles)
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
                var request = new DocumentUploadRequest
                {
                    Title = uploadModel.Title,
                    Category = uploadModel.Category,
                    Description = uploadModel.Description,
                    ProjectId = uploadModel.ProjectId,
                    Tags = uploadModel.Tags,
                    FileStream = stream,
                    OriginalFileName = file.Name,
                    ContentType = file.ContentType,
                    UploadedByUserId = currentUserId
                };

                await DocumentService.CreateDocumentAsync(request);
            }

            statusMessage = "Upload completed successfully.";
            statusClass = "alert-success";
            selectedFiles.Clear();
            tagsText = string.Empty;
            uploadModel = new DocumentUploadRequest();
        }
        catch (Exception ex)
        {
            statusMessage = $"Upload failed: {ex.Message}";
            statusClass = "alert-danger";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ClearSelection()
    {
        selectedFiles.Clear();
        tagsText = string.Empty;
        uploadModel = new DocumentUploadRequest();
        statusMessage = null;
    }
}
