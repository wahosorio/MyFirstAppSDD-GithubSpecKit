@page "/documents/shared"
@using ContosoDashboard.Services
@using ContosoDashboard.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IDocumentService DocumentService
@inject IProjectService ProjectService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Shared Documents - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h1>Shared Documents</h1>
                <p class="text-muted">Browse documents shared with you or accessible through your projects.</p>
            </div>
            <a href="/documents/upload" class="btn btn-primary">Upload Document</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Search</label>
                            <input class="form-control" @bind="searchText"
                                   placeholder="Title, description, tags, project or uploader" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Category</label>
                            <input class="form-control" @bind="category" placeholder="Category" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Project</label>
                            <select class="form-select" @bind="selectedProjectId">
                                <option value="">All projects</option>
                                @foreach (var project in projects)
                                {
                                    <option value="@project.ProjectId">@project.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Date from</label>
                            <input type="date" class="form-control" @bind="createdFrom" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Date to</label>
                            <input type="date" class="form-control" @bind="createdTo" />
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary w-100" @onclick="ApplyFilters">Search</button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (documents == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!documents.Any())
    {
        <div class="alert alert-info">No shared documents found. Adjust your filters or ask a teammate to share a document
            with you.</div>
        }
    else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Project</th>
                            <th>Owner</th>
                            <th>Uploaded</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var document in documents)
                        {
                            <tr>
                                <td>
                                    <strong>@document.Title</strong>
                                    @if (document.IsSharedWithMe)
                                    {
                                        <div><small class="text-muted">Shared with you</small></div>
                                    }
                                </td>
                                <td>@document.Category</td>
                                <td>@(document.ProjectName ?? "Personal")</td>
                                <td>@document.UploadedByName</td>
                                <td>@document.UploadDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary me-1" target="_blank"
                                       href="@($"/api/documents/{document.DocumentId}/download")">Download</a>
                                    @if (document.IsPreviewable)
                                    {
                                        <a class="btn btn-sm btn-outline-secondary" target="_blank"
                                           href="@($"/api/documents/{document.DocumentId}/preview")">Preview</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

@code {
    private List<DocumentDto>? documents;
    private List<Project> projects = new();
    private int currentUserId;

    private string? searchText;
    private string? category;
    private int? selectedProjectId;
    private DateTime? createdFrom;
    private DateTime? createdTo;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);

        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
        {
            currentUserId = userId;
            projects = await ProjectService.GetUserProjectsAsync(currentUserId);
            await LoadDocumentsAsync();
        }
    }

    private async Task LoadDocumentsAsync()
    {
        var query = new DocumentQueryParameters
        {
            SearchText = searchText,
            Category = category,
            ProjectId = selectedProjectId,
            CreatedFrom = createdFrom,
            CreatedTo = createdTo,
            PageSize = 100,
            PageNumber = 1
        };

        documents = await DocumentService.GetSharedDocumentsAsync(currentUserId, query);
    }

    private async Task ApplyFilters()
    {
        await LoadDocumentsAsync();
    }

    private async Task ResetFilters()
    {
        searchText = null;
        category = null;
        selectedProjectId = null;
        createdFrom = null;
        createdTo = null;
        await LoadDocumentsAsync();
    }
}
