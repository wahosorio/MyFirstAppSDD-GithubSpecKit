@page "/documents"
@using ContosoDashboard.Services
@using ContosoDashboard.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IDocumentService DocumentService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>My Documents - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <h1>My Documents</h1>
                <p class="text-muted">Review your uploaded documents and access them securely.</p>
            </div>
            <a href="/documents/upload" class="btn btn-primary">Upload Document</a>
        </div>
    </div>

    @if (documents == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!documents.Any())
    {
        <div class="alert alert-info">You have not uploaded any documents yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Project</th>
                        <th>Uploaded</th>
                        <th>Size</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var document in documents)
                    {
                        <tr>
                            <td>@document.Title</td>
                            <td>@document.Category</td>
                            <td>@(document.ProjectName ?? "Personal")</td>
                            <td>@document.UploadDate.ToString("MMM dd, yyyy")</td>
                            <td>@String.Format("{0:N0}", document.FileSize) bytes</td>
                            <td>@document.ScanStatus</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" target="_blank" href="@($"/api/documents/{document.DocumentId}/download")">Download</a>
                                @if (document.IsPreviewable)
                                {
                                    <a class="btn btn-sm btn-outline-secondary" target="_blank" href="@($"/api/documents/{document.DocumentId}/preview")">Preview</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<DocumentDto>? documents;
    private int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);

        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
        {
            currentUserId = userId;
            documents = await DocumentService.GetDocumentsForUserAsync(currentUserId, new DocumentQueryParameters());
        }
    }
}
